# YouTube Data API Configuration
# Get your API key from: https://console.cloud.google.com/apis/credentials

# Your YouTube Data API v3 key
YOUTUBE_API_KEY=your_api_key_here

# The YouTube channel handle (with or without @)
# Example: @mkbhd or mkbhd
YOUTUBE_CHANNEL_HANDLE=@channelhandle

# Social Media Handles (optional)
# Only include if you want these links to appear in the header
# FACEBOOK_HANDLE=your_facebook_username
# X_HANDLE=your_x_username
# TIKTOK_HANDLE=your_tiktok_username
# INSTAGRAM_HANDLE=your_instagram_username

# Security Settings
# Comma-separated list of allowed origins for CORS (leave empty for all)
# ALLOWED_ORIGINS=https://example.com,https://www.example.com
NODE_ENV=production

# Content Settings
# Number of days to look back for "recent" content on the home page
# Default: 7
RECENT_DAYS=7
