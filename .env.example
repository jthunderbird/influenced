# YouTube Data API Configuration
# Get your API key from: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your_api_key_here
YOUTUBE_CHANNEL_HANDLE=@channelhandle
CACHE_DIR=/app/.cache

# Content Settings
RECENT_DAYS=7
RECENT_VIDEOS=10

# Social Media Handles (optional)
# INSTAGRAM_HANDLE=your_instagram_username
# FACEBOOK_HANDLE=your_facebook_username
# X_HANDLE=your_x_username
# TIKTOK_HANDLE=your_tiktok_username

# Admin Panel Login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Password!123

# Security - disable helmet when behind a reverse proxy handling TLS
USE_HELMET=false
USE_RATE_LIMIT=false
ALLOWED_ORIGINS=

# Store Configuration
STORE_ENABLED=false
STORE_NAME=Merch Store
STORE_CURRENCY=USD

# Medusa E-commerce Settings
MEDUSA_URL=http://medusa:9000
MEDUSA_PUBLISHABLE_KEY=pk_your_publishable_key
MEDUSA_ADMIN_EMAIL=admin@yourdomain.local
MEDUSA_ADMIN_PASSWORD=your_medusa_password

# Seed the database with sample products on first run
SEED_DATABASE=false

# Stripe (required for payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Shopify (optional - alternative to Medusa)
# SHOPIFY_STORE_URL=https://your-store.myshopify.com
# SHOPIFY_ACCESS_TOKEN=shpat_xxxxx

# BigCommerce (optional - alternative to Medusa)
# BIGCOMMERCE_STORE_URL=https://store-xxxxx.mybigcommerce.com
# BIGCOMMERCE_ACCESS_TOKEN=xxxxx
# BIGCOMMERCE_CLIENT_ID=xxxxx
# BIGCOMMERCE_CLIENT_SECRET=xxxxx

# Docker Environment
JWT_SECRET=supersecret_jwt_key_change_in_production
COOKIE_SECRET=supersecret_cookie_change_in_production
